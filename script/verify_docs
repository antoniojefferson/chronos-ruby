#!/usr/bin/env ruby
# encoding: UTF-8

require "json"

def read_utf8(path)
  File.open(path, "r:UTF-8", &:read)
end

def readlines_utf8(path)
  File.open(path, "r:UTF-8", &:readlines)
end

root = File.expand_path("..", __dir__)
required_documents = %w(
  README.md
  CHANGELOG.md
  CONTRIBUTING.md
  SECURITY.md
  docs/architecture.md
  docs/compatibility.md
  docs/configuration.md
  docs/data-collected.md
  docs/privacy-lgpd.md
  docs/performance.md
  docs/troubleshooting.md
  docs/modules/configuration.md
  docs/modules/notice-pipeline.md
  docs/modules/sanitization.md
  docs/modules/serialization.md
  docs/modules/transport.md
  docs/modules/async-queue.md
  docs/modules/retry-backlog.md
  docs/modules/remote-configuration.md
  docs/modules/rack-context.md
  docs/modules/rails-legacy.md
  docs/modules/telemetry-events.md
  docs/modules/sidekiq-legacy.md
)

missing = required_documents.reject { |path| File.file?(File.join(root, path)) }
abort "Missing documentation: #{missing.join(', ')}" unless missing.empty?

Dir[File.join(root, "lib/**/*.rb")].each do |path|
  lines = readlines_utf8(path)
  lines.each_with_index do |line, index|
    next unless line =~ /^\s*class\s+[A-Z]/

    comments = lines[[index - 16, 0].max...index].join
    abort "Undocumented public class at #{path}:#{index + 1}" unless comments.include?("@responsibility")
  end
end

schema_path = File.join(root, "contracts/event-v1.schema.json")
schema = JSON.parse(read_utf8(schema_path))
abort "Contract schema must be version 1.0" unless schema["properties"]["schema_version"]["const"] == "1.0"
rails_types = %w(request query job cache)
unless (rails_types - schema["properties"]["event_type"]["enum"]).empty?
  abort "Contract schema is missing Rails telemetry event types"
end

rack_schema_path = File.join(root, "contracts/rack-context-v1.schema.json")
rack_schema = JSON.parse(read_utf8(rack_schema_path))
abort "Rack context contract must require trace isolation" unless rack_schema["required"].include?("trace_id")

readme = read_utf8(File.join(root, "README.md"))
abort "README contains a placeholder" if readme =~ /TODO|UPDATE_WITH|\[USERNAME\]/
abort "README does not document version 0.5 Rails integration" unless readme.include?("Version 0.5")
abort "README does not document version 0.6 Sidekiq integration" unless readme.include?("Version 0.6")

sidekiq_schema_path = File.join(root, "contracts/sidekiq-job-v1.schema.json")
sidekiq_schema = JSON.parse(read_utf8(sidekiq_schema_path))
unless sidekiq_schema["properties"]["arguments"]["maxItems"] == 20
  abort "Sidekiq job contract must bound arguments"
end

privacy = read_utf8(File.join(root, "docs/privacy-lgpd.md"))

%w(password token cookie CPF CNPJ health financial audit).each do |topic|
  abort "Privacy documentation is missing #{topic}" unless privacy.downcase.include?(topic.downcase)
end

puts "Documentation verification passed"
