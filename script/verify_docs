#!/usr/bin/env ruby
# encoding: UTF-8

require "json"

def read_utf8(path)
  File.open(path, "r:UTF-8", &:read)
end

def readlines_utf8(path)
  File.open(path, "r:UTF-8", &:readlines)
end

root = File.expand_path("..", __dir__)
required_documents = %w(
  README.md
  CHANGELOG.md
  CONTRIBUTING.md
  SECURITY.md
  docs/architecture.md
  docs/compatibility.md
  docs/configuration.md
  docs/data-collected.md
  docs/privacy-lgpd.md
  docs/performance.md
  docs/troubleshooting.md
  docs/modules/configuration.md
  docs/modules/notice-pipeline.md
  docs/modules/sanitization.md
  docs/modules/serialization.md
  docs/modules/transport.md
  docs/modules/async-queue.md
  docs/modules/retry-backlog.md
  docs/modules/remote-configuration.md
  docs/modules/rack-context.md
  docs/modules/rails-legacy.md
  docs/modules/telemetry-events.md
  docs/modules/sidekiq-legacy.md
  docs/modules/apm-aggregation.md
  docs/modules/external-http.md
  docs/modules/cache-observability.md
  docs/modules/dependencies.md
  docs/modules/deploy-tracking.md
  docs/modules/integration-verification.md
  docs/modules/ignore-rules.md
  docs/modules/active-job.md
  docs/migration-from-airbrake.md
  docs/semver.md
  docs/deprecation-policy.md
  docs/security-review.md
  docs/protocol-v1.md
  docs/release-1.0-readiness.md
)

missing = required_documents.reject { |path| File.file?(File.join(root, path)) }
abort "Missing documentation: #{missing.join(', ')}" unless missing.empty?

Dir[File.join(root, "lib/**/*.rb")].each do |path|
  lines = readlines_utf8(path)
  lines.each_with_index do |line, index|
    next unless line =~ /^\s*class\s+[A-Z]/

    comments = lines[[index - 16, 0].max...index].join
    abort "Undocumented public class at #{path}:#{index + 1}" unless comments.include?("@responsibility")
  end
end

schema_path = File.join(root, "contracts/event-v1.schema.json")
schema = JSON.parse(read_utf8(schema_path))
abort "Contract schema must be version 1.0" unless schema["properties"]["schema_version"]["const"] == "1.0"
telemetry_types = %w(request query job cache external_http dependencies deploy metric_batch)
unless (telemetry_types - schema["properties"]["event_type"]["enum"]).empty?
  abort "Contract schema is missing supported telemetry event types"
end

rack_schema_path = File.join(root, "contracts/rack-context-v1.schema.json")
rack_schema = JSON.parse(read_utf8(rack_schema_path))
abort "Rack context contract must require trace isolation" unless rack_schema["required"].include?("trace_id")

verification_path = File.join(root, "contracts/integration-verification-response-v1.schema.json")
verification_schema = JSON.parse(read_utf8(verification_path))
unless verification_schema["additionalProperties"] == false &&
       verification_schema["required"].include?("verification_id") &&
       verification_schema["required"].include?("credentials_valid") &&
       verification_schema["required"].include?("event_received")
  abort "Integration verification response contract must be strict and correlated"
end

readme = read_utf8(File.join(root, "README.md"))
abort "README contains a placeholder" if readme =~ /TODO|UPDATE_WITH|\[USERNAME\]/
abort "README does not document version 0.5 Rails integration" unless readme.include?("Version 0.5")
abort "README does not document version 0.6 Sidekiq integration" unless readme.include?("0.6.0.pre.1")
abort "README does not document version 0.7 APM aggregation" unless readme.include?("Version 0.7")
abort "README does not document version 0.8 observability" unless readme.include?("Version 0.8")
abort "README does not document version 0.9 deploy tracking" unless readme.include?("Version 0.9")
abort "README does not document local ignore rules" unless readme.include?("Chronos.ignore_if")
abort "README does not document Active Job propagation" unless readme.include?("namespaced serialized field")
unless readme.include?("chronos:verify_integration") && readme.include?("Chronos.verify_integration")
  abort "README does not document integration verification"
end

%w(benchmarks/comparative.rb benchmarks/fake_endpoint_load.rb script/generate_sbom).each do |relative_path|
  abort "Missing release gate: #{relative_path}" unless File.file?(File.join(root, relative_path))
end

apm_schema_path = File.join(root, "contracts/apm-batch-v1.schema.json")
apm_schema = JSON.parse(read_utf8(apm_schema_path))
abort "APM batches must be bounded to 50 metrics" unless apm_schema["properties"]["metrics"]["maxItems"] == 50

sidekiq_schema_path = File.join(root, "contracts/sidekiq-job-v1.schema.json")
sidekiq_schema = JSON.parse(read_utf8(sidekiq_schema_path))
unless sidekiq_schema["properties"]["arguments"]["maxItems"] == 20
  abort "Sidekiq job contract must bound arguments"
end

dependencies_path = File.join(root, "contracts/dependencies-v1.schema.json")
dependencies_schema = JSON.parse(read_utf8(dependencies_path))
unless dependencies_schema["properties"]["dependencies"]["maxItems"] == 200
  abort "Dependency inventory contract must be bounded to 200 entries"
end

deploy_path = File.join(root, "contracts/deploy-v1.schema.json")
deploy_schema = JSON.parse(read_utf8(deploy_path))
unless deploy_schema["properties"]["repository"]["maxLength"] == 512
  abort "Deploy repository field must be bounded"
end
correlation = schema["properties"]["correlation"]
unless correlation && correlation["required"] == %w(release revision deploy_id environment service region instance)
  abort "Event correlation contract is incomplete"
end

privacy = read_utf8(File.join(root, "docs/privacy-lgpd.md"))

%w(password token cookie CPF CNPJ health financial audit).each do |topic|
  abort "Privacy documentation is missing #{topic}" unless privacy.downcase.include?(topic.downcase)
end

puts "Documentation verification passed"
