{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chronos.example/schemas/event-v1.schema.json",
  "title": "Chronos event envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "occurred_at",
    "sent_at",
    "project_key",
    "environment",
    "service",
    "runtime",
    "context",
    "payload"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "event_id": {"type": "string", "minLength": 1},
    "event_type": {"enum": ["exception", "request", "query", "job", "cache", "external_http", "dependencies", "deploy", "metric_batch"]},
    "occurred_at": {"type": "string"},
    "sent_at": {"type": "string"},
    "project_key": {"type": "string", "minLength": 1},
    "environment": {"type": "string"},
    "service": {
      "type": "object",
      "required": ["name", "version", "instance_id"],
      "properties": {
        "name": {"type": ["string", "null"]},
        "version": {"type": ["string", "null"]},
        "instance_id": {"type": ["string", "null"]}
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release", "revision", "deploy_id", "environment", "service", "region", "instance"],
      "properties": {
        "release": {"type": ["string", "null"], "maxLength": 128},
        "revision": {"type": ["string", "null"], "maxLength": 128},
        "deploy_id": {"type": ["string", "null"], "maxLength": 128},
        "environment": {"type": ["string", "null"], "maxLength": 128},
        "service": {"type": ["string", "null"], "maxLength": 128},
        "region": {"type": ["string", "null"], "maxLength": 128},
        "instance": {"type": ["string", "null"], "maxLength": 128}
      }
    },
    "runtime": {"type": "object"},
    "context": {"type": "object"},
    "payload": {"type": "object"}
  },
  "allOf": [
    {
      "if": {
        "required": ["event_type"],
        "properties": {
          "event_type": {"const": "exception"}
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["exception", "severity"],
            "properties": {
              "exception": {
                "type": "object",
                "required": ["class", "message", "backtrace", "causes"]
              },
              "severity": {"type": "string"}
            }
          }
        }
      }
    }
  ]
}
